{
  "name": "@ambe/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx --ignore-pattern next-env.d.ts",
    "test": "node ../../scripts/run-ts-tests.mjs lib app",
    "test:trade": "pnpm exec tsx --test lib/tradeAccessValidation.test.ts app/trade-access/page.test.tsx app/sitemap.test.ts app/robots.test.ts lib/middleware.test.ts && pnpm exec playwright test e2e/trade-access-rfq.spec.ts",
    "test:account-opening": "pnpm exec tsx --test lib/accountOpeningDownloadSafety.test.ts lib/accountOpeningSafetyReviewSections.test.tsx app/dashboard/account-opening/AccountOpeningCasesContent.test.tsx",
    "test:e2e": "playwright test",
    "test:e2e:local-runtime": "playwright test --config=playwright.local-runtime.config.ts"
  },
  "dependencies": {
    "@ambe/shared": "workspace:*",
    "next": "^15.5.19",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "tsx": "^4.19.3"
  }
}
