  isActive            Boolean       @default(true)
  opportunities       Opportunity[]
  salesRecords        SalesRecord[]
  customerDemandSignals CustomerDemandSignal[]
  demandSupplyMatches DemandSupplyMatch[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([normalizedName])
}

model SalesRecord {
  id                    String       @id @default(cuid())
  importBatchId         String?
  saleDate              DateTime
  customerId            String
  productId             String
  supplierId            String?
  rawProductName        String
  rawCustomerName       String
  rawSupplierName       String?
  normalizedProductName String?
  candidateStrength     String?
  candidateFormulation  String?
  candidatePackSize     String?
  quantity              Int
  unitPrice             Decimal      @db.Decimal(12, 2)
  totalRevenue          Decimal      @db.Decimal(14, 2)
  currencyCode          String       @default("USD")
  rawRow                Json?
  importBatch           ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  customer              Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product               Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier              Supplier?    @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([saleDate])
  @@index([customerId, saleDate])
  @@index([productId, saleDate])
}

model Opportunity {
  id            String            @id @default(cuid())
  type          OpportunityType
  status        OpportunityStatus @default(OPEN)
  title         String
  description   String?
  score         Int
  metadata      Json?
  customerId    String?
  productId     String?
  supplierId    String?
  ownerUserId   String?
  dueDate       DateTime?
  customer      Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  owner         User?             @relation("OpportunityOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  product       Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  supplier      Supplier?         @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  alerts        Alert[]
  telegramPosts TelegramPost[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([type, status])
  @@index([customerId])
  @@index([productId])
}

model Alert {
  id            String       @id @default(cuid())
  type          AlertType
  status        AlertStatus  @default(OPEN)
  title         String
  message       String
  userId        String?
  opportunityId String?
  triggeredAt   DateTime     @default(now())
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status, triggeredAt])
  @@index([userId])
}

model TelegramPost {
  id                String             @id @default(cuid())
  opportunityId     String?
  channelKey        String
  status            TelegramPostStatus @default(PENDING)
  messageText       String
  contentHash       String?
  telegramMessageId String?
  sentAt            DateTime?
  errorMessage      String?
  metadata          Json?
  opportunity       Opportunity?       @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([channelKey, status])
  @@index([opportunityId, channelKey, status])
}

model TelegramInboundItem {
  id                   String                          @id @default(cuid())
  telegramMessageId    String
  telegramUserId       String?
  telegramChatId       String
  senderDisplayName    String?
  fileType             TelegramInboundFileType         @default(UNKNOWN)
  fileName             String?
  mimeType             String?
  telegramFileId       String?
  telegramFileUniqueId String?
  caption              String?
  processingStatus     TelegramInboundProcessingStatus @default(RECEIVED)
  linkedImportBatchId  String?
  errorMessage         String?
  metadata             Json?
  linkedImportBatch    ImportBatch?                    @relation(fields: [linkedImportBatchId], references: [id], onDelete: SetNull)
  createdAt            DateTime                        @default(now())
  updatedAt            DateTime                        @updatedAt

  @@unique([telegramChatId, telegramMessageId])
  @@index([processingStatus, createdAt])
}

model AppSetting {
  id          String      @id @default(cuid())
  key         String      @unique
  value       String
  type        SettingType @default(STRING)
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model PurchaseOrderImport {
  id            String                    @id @default(cuid())
  status        PurchaseOrderImportStatus @default(COMPLETED)
  fileName      String
  fileMimeType  String?
  fileSizeBytes Int?
  totalRows     Int                       @default(0)
  importedRows  Int                       @default(0)
  reviewRows    Int                       @default(0)
  ignoredRows   Int                       @default(0)
  warnings      Json?
  uploadedByType String                   @default("SYSTEM")
  uploadedByIdentifier String?
  lines         PurchaseOrderLine[]
  uploadedAt    DateTime                  @default(now())
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  @@index([status, uploadedAt])
}

model PurchaseOrderLine {
  id                    String                  @id @default(cuid())
  purchaseOrderImportId String
  sourceRowNumber       Int
  rawRow                Json
  poNumber              String?
  orderDate             DateTime?
  supplierText          String?
  productText           String?
  manufacturerText      String?
  quantity              Int?
  unitPrice             Decimal?                @db.Decimal(12, 2)
  currency              String?
  minimumOrderQuantity  Int?
  matchedProductId      String?
  matchedSupplierId     String?
  productMatchConfidence Int?
  supplierMatchConfidence Int?
  matchReason           String?
  matchEvidence         Json?
  status                PurchaseOrderLineStatus @default(NEEDS_REVIEW)
  reviewReason          String?
  purchaseOrderImport   PurchaseOrderImport     @relation(fields: [purchaseOrderImportId], references: [id], onDelete: Cascade)
  matchedProduct        Product?                @relation(fields: [matchedProductId], references: [id], onDelete: SetNull)
  matchedSupplier       Supplier?               @relation(fields: [matchedSupplierId], references: [id], onDelete: SetNull)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([purchaseOrderImportId, sourceRowNumber])
  @@index([matchedProductId, orderDate])
  @@index([matchedSupplierId, orderDate])
  @@index([status, createdAt])
}

model RegulatoryUpdate {
  id          String                 @id @default(cuid())
  sourceUrl   String                 @unique
  title       String
  publishedAt DateTime?
  rawText     String
  regulator   String                 @default("MHRA")
  category    String?
  evidence    Json?
  contentHash String
  signals     RegulatorySignal[]
  actionLogs  RegulatoryActionLog[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([regulator, publishedAt])
  @@index([contentHash])
}

model RegulatorySignal {
  id                  String                   @id @default(cuid())
  regulatoryUpdateId  String
  eventType           RegulatoryEventType
  severity            RegulatorySeverity       @default(MEDIUM)
  summary             String
  affectedProductText String?
  activeSubstance     String?
  manufacturer        String?
  licenceNumber       String?
  batchNumber         String?
  parserVersion       String
  confidence          Int                      @default(50)
  evidence            Json?
  regulatoryUpdate    RegulatoryUpdate         @relation(fields: [regulatoryUpdateId], references: [id], onDelete: Cascade)
  productMatches      RegulatoryProductMatch[]
  alerts              RegulatoryAlert[]
  reviewItems         RegulatoryReviewItem[]
  actionLogs          RegulatoryActionLog[]
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([regulatoryUpdateId, eventType])
  @@index([eventType, severity, createdAt])
}

model RegulatoryProductMatch {
  id                 String                @id @default(cuid())
  regulatorySignalId String
  productId          String?
  status             RegulatoryMatchStatus @default(UNCLEAR)
  confidence         Int                   @default(0)
  reason             String
  matchedFields      Json?
  evidence           Json?
  regulatorySignal   RegulatorySignal      @relation(fields: [regulatorySignalId], references: [id], onDelete: Cascade)
  product            Product?              @relation(fields: [productId], references: [id], onDelete: SetNull)
  alert              RegulatoryAlert?
  reviewItems        RegulatoryReviewItem[]
  actionLogs         RegulatoryActionLog[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([regulatorySignalId, status, confidence])
  @@index([productId, status])
}

model RegulatoryAlert {
  id                       String                 @id @default(cuid())
  regulatorySignalId       String
  regulatoryProductMatchId String?                @unique
  productId                String?
  status                   RegulatoryAlertStatus  @default(NEW)
  title                    String
  message                  String
  suggestedAction          String
  evidence                 Json?
  regulatorySignal         RegulatorySignal       @relation(fields: [regulatorySignalId], references: [id], onDelete: Cascade)
  regulatoryProductMatch   RegulatoryProductMatch? @relation(fields: [regulatoryProductMatchId], references: [id], onDelete: SetNull)
  product                  Product?               @relation(fields: [productId], references: [id], onDelete: SetNull)
  actionLogs               RegulatoryActionLog[]
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  @@index([status, createdAt])
  @@index([productId, status])
  @@index([regulatorySignalId])
}

model RegulatoryReviewItem {
  id                       String                 @id @default(cuid())
  regulatorySignalId       String
  regulatoryProductMatchId String?
  productId                String?
  status                   RegulatoryReviewStatus @default(NEW)
  priority                 RegulatorySeverity     @default(MEDIUM)
  reason                   String
  latestNote               String?
  assigneeLabel            String?
  completedAt              DateTime?
  regulatorySignal         RegulatorySignal       @relation(fields: [regulatorySignalId], references: [id], onDelete: Cascade)
  regulatoryProductMatch   RegulatoryProductMatch? @relation(fields: [regulatoryProductMatchId], references: [id], onDelete: SetNull)
  product                  Product?               @relation(fields: [productId], references: [id], onDelete: SetNull)
  actionLogs               RegulatoryActionLog[]
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  @@index([status, priority, createdAt])
  @@index([regulatorySignalId, status])
  @@index([productId, status])
}

model RegulatoryActionLog {
  id                       String                @id @default(cuid())
  regulatoryUpdateId       String?
  regulatorySignalId       String?
  regulatoryProductMatchId String?
  regulatoryAlertId        String?
  regulatoryReviewItemId   String?
  actionType               RegulatoryActionType
  previousStatus           String?
  newStatus                String?
  actorType                String                @default("SYSTEM")
  actorIdentifier          String?
  note                     String?
  metadata                 Json?
  regulatoryUpdate         RegulatoryUpdate?      @relation(fields: [regulatoryUpdateId], references: [id], onDelete: SetNull)
  regulatorySignal         RegulatorySignal?      @relation(fields: [regulatorySignalId], references: [id], onDelete: SetNull)
  regulatoryProductMatch   RegulatoryProductMatch? @relation(fields: [regulatoryProductMatchId], references: [id], onDelete: SetNull)
  regulatoryAlert          RegulatoryAlert?       @relation(fields: [regulatoryAlertId], references: [id], onDelete: SetNull)
  regulatoryReviewItem     RegulatoryReviewItem?  @relation(fields: [regulatoryReviewItemId], references: [id], onDelete: SetNull)
  createdAt                DateTime              @default(now())

  @@index([regulatoryUpdateId, createdAt])
  @@index([regulatorySignalId, createdAt])
  @@index([regulatoryAlertId, createdAt])
  @@index([regulatoryReviewItemId, createdAt])
}
