model User {
  id                         String              @id @default(cuid())
  email                      String              @unique
  fullName                   String
  role                       UserRole            @default(ANALYST)
  isActive                   Boolean             @default(true)
  alerts                     Alert[]
  opportunities              Opportunity[]       @relation("OpportunityOwner")
  assignedOfferWorkflowItems OfferWorkflowItem[]
  ownedTradeOpportunities    TradeOpportunity[]  @relation("TradeOpportunityOwner")
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
}

model Product {
  id                        String              @id @default(cuid())
  sku                       String?             @unique
  name                      String
  /// Current imports persist the composite normalized product key here.
  /// This is not guaranteed to be the base-name-style normalized text.
  normalizedName            String
  /// Base-name-style normalized product text emitted by the normalizer when available.
  baseName                  String?
  manufacturer              String?
  strength                  String?
  dosageForm                String?
  packSize                  String?
  isActive                  Boolean             @default(true)
  aliases                   ProductAlias[]
  inventorySnapshots        InventorySnapshot[]
  opportunities             Opportunity[]
  salesRecords              SalesRecord[]
  supplierPriceItems        SupplierPriceItem[]
  buyDecisions              BuyDecision[]
  buyExecutions             BuyExecution[]
  tradeOpportunities        TradeOpportunity[]
  correctedOfferCorrections OfferCorrection[]
  regulatoryProductMatches  RegulatoryProductMatch[]
  regulatoryAlerts          RegulatoryAlert[]
  regulatoryReviewItems     RegulatoryReviewItem[]
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt

  @@index([normalizedName])
}

model ProductAlias {
  id           String   @id @default(cuid())
  productId    String
  aliasName    String
  sourceSystem String?
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([aliasName])
  @@index([productId])
}

model ImportBatch {
  id                   String                @id @default(cuid())
  kind                 ImportKind
  status               ImportStatus          @default(COMPLETED)
  fileName             String
  fileMimeType         String?
  fileSizeBytes        Int?
  // Stable idempotency key for email-attachment imports (sha256 over source
  // system + email id + attachment id + content checksum + import kind). Null
  // for manual uploads, which are intentionally never deduplicated. The unique
  // index makes "already imported" detection atomic and race-safe.
  sourceAttachmentFingerprint String?         @unique
  totalRows            Int                   @default(0)
  validRows            Int                   @default(0)
  invalidRows          Int                   @default(0)
  warnings             Json?
  diagnostics          Json?
  errors               ImportError[]
  telegramInboundItems TelegramInboundItem[]
  inventorySnapshots   InventorySnapshot[]
  salesRecords         SalesRecord[]
  supplierPriceList    SupplierPriceList?
  uploadedAt           DateTime              @default(now())
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([kind, uploadedAt])
}

model ImportError {
  id            String      @id @default(cuid())
  importBatchId String
  rowNumber     Int?
  fieldName     String?
  message       String
  rawRow        Json?
  importBatch   ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([importBatchId, rowNumber])
}

model Supplier {
  id                        String                     @id @default(cuid())
  name                      String
  normalizedName            String
  country                   String?
  contactEmail              String?
  reliabilityScore          Float                      @default(0.5)
  isActive                  Boolean                    @default(true)
  inventorySnapshots        InventorySnapshot[]
  opportunities             Opportunity[]
  priceLists                SupplierPriceList[]
  salesRecords              SalesRecord[]
  supplierPriceItems        SupplierPriceItem[]
  qualification             SupplierQualification?
  supplierContacts          SupplierContact[]
  buyDecisions              BuyDecision[]
  buyExecutions             BuyExecution[]
  tradeOpportunities        TradeOpportunity[]
  correctedOfferCorrections OfferCorrection[]
  sourceReliabilityProfiles SourceReliabilityProfile[]
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  @@unique([normalizedName])
}

model InboundEmail {
  id                        String                       @id @default(cuid())
  sourceSystem              String                       @default("MICROSOFT_GRAPH")
  externalMessageId         String?
  internetMessageId         String?
  conversationId            String?
  fromEmail                 String
  fromName                  String?
  subject                   String?
  rawHtml                   String?
  rawText                   String?
  bodyHash                  String?
  senderDomain              String?
  sourceTemplateFingerprint String?
  attachmentSummary         Json?
  processingStatus          InboundEmailProcessingStatus @default(RECEIVED)
  triageStatus              String?
  sourceTrustScore          Int?
  structureConfidence       Int?
  businessWorthinessScore   Int?
  parserConfidence          String?
  reviewReason              String?
  receivedAt                DateTime?
  processedAt               DateTime?
  documents                 InboundEmailDocument[]
  extractionRuns            EmailExtractionRun[]
  derivedOffers             EmailDerivedOffer[]
  offerWorkflowItems        OfferWorkflowItem[]
  buyDecisions              BuyDecision[]
  tradeOpportunities        TradeOpportunity[]
  offerCorrections          OfferCorrection[]
  promotionDecisions        PromotionDecision[]
  promotedPriceLists        SupplierPriceList[]
  accountOpeningCases       AccountOpeningCase[]
  supplierContacts          SupplierContact[]
  accountOpeningOriginalDocuments AccountOpeningOriginalDocument[]
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt

  @@unique([sourceSystem, externalMessageId])
  @@index([fromEmail, createdAt])
  @@index([senderDomain, createdAt])
  @@index([sourceSystem, sourceTemplateFingerprint])
  @@index([processingStatus, createdAt])
}

model AccountOpeningCase {
  id                    String                         @id @default(cuid())
  inboundEmailId        String?
  messageId             String?
  senderEmail           String?
  senderDomain          String?
  subject               String?
  receivedAt            DateTime?
  companyName           String?
  detectedFormType      String?
  status                AccountOpeningStatus           @default(PENDING_REVIEW)
  recommendedSigner     String                         @default("Aman Dhillon")
  signingStatement      String                         @default("Aman Dhillon can sign this account-opening form by default.")
  signingExplanation    String?
  detectedNames         Json?
  detectedRoles         Json?
  escalationNotes       Json?
  riskFlags             Json?
  missingFields         Json?
  reviewerChecks        Json?
  signingNotes          Json?
  missingInfoResponses  Json?
  extractedTextSummary  String?
  storageStatus         String?
  storageNote           String?
  storageSkippedReason  String?
  storageLastAttemptAt  DateTime?
  storageFolderUrl      String?
  sourceAttachmentNames Json?
  draftStatus           String?
  draftVersion          String?
  draftGeneratedAt      DateTime?
  draftJson             Json?
  draftSummary          Json?
  sourceFingerprint     String                         @unique
  inboundEmail          InboundEmail?                  @relation(fields: [inboundEmailId], references: [id], onDelete: SetNull)
  events                AccountOpeningCaseEvent[]
  sourceEvidence        AccountOpeningSourceEvidence[]
  fieldMappings         AccountOpeningFieldMapping[]
  originalForms         AccountOpeningOriginalForm[]
  fillPreviews          AccountOpeningFillPreview[]
  binaryFillPreviews    AccountOpeningBinaryFillPreview[]
  completedFormFilings  AccountOpeningCompletedFormFiling[]
  originalDocuments     AccountOpeningOriginalDocument[]
  processingRuns        AccountOpeningProcessingRun[]
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt

  @@index([status, updatedAt])
  @@index([messageId])
  @@index([senderEmail])
}

model AccountOpeningProcessingRun {
  id                   String             @id @default(cuid())
  accountOpeningCaseId String
  triggerType          String
  status               String
  startedAt            DateTime
  finishedAt           DateTime?
  warningSummary       String?
  errorSummary         String?
  diagnostics          Json?
  actorType            String             @default("SYSTEM")
  actorIdentifier      String?
  accountOpeningCase   AccountOpeningCase @relation(fields: [accountOpeningCaseId], references: [id], onDelete: Cascade)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([accountOpeningCaseId, startedAt])
  @@index([triggerType, status, startedAt])
}

model AccountOpeningCaseEvent {
  id                   String                @id @default(cuid())
  accountOpeningCaseId String
  actionType           String
  previousStatus       AccountOpeningStatus?
  newStatus            AccountOpeningStatus?
  actorType            String                @default("SYSTEM")
  actorIdentifier      String?
  note                 String?
  metadata             Json?
  accountOpeningCase   AccountOpeningCase    @relation(fields: [accountOpeningCaseId], references: [id], onDelete: Cascade)
  createdAt            DateTime              @default(now())

  @@index([accountOpeningCaseId, createdAt])
}

model AccountOpeningSourceEvidence {
  id                   String                       @id @default(cuid())
  accountOpeningCaseId String
  sourceType           String
  sourceLabel          String?
  fileName             String?
  mimeType             String?
  sizeBytes            Int?
  contentId            String?
  disposition          String?
  extractionMethod     String?
  extractedTextHash    String?
  extractedTextChars   Int?
  safeSnippet          String?
  rawFileAvailable     Boolean                      @default(false)
  storageProvider      String?
  storageFolderUrl     String?
  storageFileUrl       String?
  storageDriveItemId   String?
  metadata             Json?
  accountOpeningCase   AccountOpeningCase           @relation(fields: [accountOpeningCaseId], references: [id], onDelete: Cascade)
  fieldMappings        AccountOpeningFieldMapping[]
  originalForms        AccountOpeningOriginalForm[]
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt

  @@index([accountOpeningCaseId, sourceType])
  @@index([extractedTextHash])
}

model AccountOpeningFieldMapping {
  id                     String                        @id @default(cuid())
  accountOpeningCaseId   String
  supplierFieldLabel     String
  supplierSectionLabel   String?
  normalizedLabel        String
  sourceType             String
  sourceEvidenceId       String?
  evidenceSnippet        String?
  suggestedDraftFieldKey String?
  mappedDraftFieldKey    String?
  proposedValue          String?
  valueSource            String?
  confidence             String
  riskLevel              String
  status                 String
  requiresReview         Boolean                       @default(true)
  blockedReason          String?
  reviewReason           String?
  operatorNote           String?
  sortOrder              Int                           @default(0)
  accountOpeningCase     AccountOpeningCase            @relation(fields: [accountOpeningCaseId], references: [id], onDelete: Cascade)
  sourceEvidence         AccountOpeningSourceEvidence? @relation(fields: [sourceEvidenceId], references: [id], onDelete: SetNull)
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt

  @@index([accountOpeningCaseId, sortOrder])
  @@index([accountOpeningCaseId, status])
  @@index([sourceEvidenceId])
}

model AccountOpeningOriginalForm {
  id                   String                       @id @default(cuid())
  accountOpeningCaseId String
  sourceEvidenceId     String?
  fileName             String
  mimeType             String?
  sizeBytes            Int?
  fileHash             String?
  storageProvider      String?
  storageFolderUrl     String?
  storageFileUrl       String?
  storageDriveItemId   String?
  localBlobAvailable   Boolean                      @default(false)
  formType             String                       @default("UNKNOWN")
  fillSupportStatus    String                       @default("UNSUPPORTED")
  detectedFieldCount   Int?
  detectionSummary     Json?
  accountOpeningCase   AccountOpeningCase           @relation(fields: [accountOpeningCaseId], references: [id], onDelete: Cascade)
  sourceEvidence       AccountOpeningSourceEvidence? @relation(fields: [sourceEvidenceId], references: [id], onDelete: SetNull)
  fillPreviews         AccountOpeningFillPreview[]
  binaryFillPreviews   AccountOpeningBinaryFillPreview[]
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt

  @@index([accountOpeningCaseId, createdAt])
  @@index([sourceEvidenceId])
  @@index([fileHash])
}

model AccountOpeningFillPreview {
  id                   String                      @id @default(cuid())
  accountOpeningCaseId String
  originalFormId       String?
  status               String                      @default("GENERATED_FOR_REVIEW")
  previewVersion       String                      @default("fill-preview-v1")
  fileNames            Json
  previewJson          Json
  fieldSummary         Json?
  safetySummary        Json?
  createdByType        String?
  createdByIdentifier  String?
  accountOpeningCase   AccountOpeningCase          @relation(fields: [accountOpeningCaseId], references: [id], onDelete: Cascade)
  originalForm         AccountOpeningOriginalForm? @relation(fields: [originalFormId], references: [id], onDelete: SetNull)
  createdAt            DateTime                    @default(now())

  @@index([accountOpeningCaseId, createdAt])
  @@index([originalFormId, createdAt])
}

model AccountOpeningBinaryFillPreview {
  id                       String                      @id @default(cuid())
  accountOpeningCaseId     String
  originalFormId           String?
  status                   String                      @default("UNSUPPORTED")
  previewVersion           String                      @default("binary-fill-preview-v1")
  binaryPreviewFileName    String?
  binaryPreviewContentType String?
  binaryPreviewHash        String?
  binaryPreviewBytes       Bytes?
  filledFieldCount         Int                         @default(0)
  blankFieldCount          Int                         @default(0)
  unsupportedReason        String?
  warnings                 Json?
  brandingPreservationCheck Json?
  safetySummary            Json?
  createdByType            String?
  createdByIdentifier      String?
  accountOpeningCase       AccountOpeningCase          @relation(fields: [accountOpeningCaseId], references: [id], onDelete: Cascade)
  originalForm             AccountOpeningOriginalForm? @relation(fields: [originalFormId], references: [id], onDelete: SetNull)
  createdAt                DateTime                    @default(now())

  @@index([accountOpeningCaseId, createdAt])
  @@index([originalFormId, createdAt])
  @@index([status, createdAt])
}

model AccountOpeningCompletedFormFiling {
  id                   String    @id @default(cuid())
  accountOpeningCaseId String
  binaryFillPreviewId  String
  status               String
  fileName             String
  contentType          String
  fileHash             String?
  fileSizeBytes        Int?
  storageProvider      String?
  storageFolderUrl     String?
  storageFileUrl       String?
  storageDriveItemId   String?
  approvedByType       String?
  approvedByIdentifier String?
  approvedAt           DateTime?
  approvalNote         String?
  filedByType          String?
  filedByIdentifier    String?
  filedAt              DateTime?
  filingNote           String?
  skippedReason        String?
  safetySummary        Json?
  metadata             Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  accountOpeningCase AccountOpeningCase @relation(fields: [accountOpeningCaseId], references: [id], onDelete: Cascade)

  @@index([accountOpeningCaseId, createdAt])
  @@index([binaryFillPreviewId])
  @@index([status, createdAt])
}

model InboundEmailDocument {
  id             String                      @id @default(cuid())
  inboundEmailId String
  kind           InboundEmailDocumentKind
  documentIndex  Int
  label          String?
  textContent    String
  metadata       Json?
  inboundEmail   InboundEmail                @relation(fields: [inboundEmailId], references: [id], onDelete: Cascade)
  derivedOffers  EmailDerivedOffer[]
  evidences      EmailDerivedOfferEvidence[]
  supplierContacts SupplierContact[]
  supplierContactEvidence SupplierContactEvidence[]
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  @@unique([inboundEmailId, kind, documentIndex])
  @@index([inboundEmailId, kind, documentIndex])
}

model EmailExtractionRun {
  id               String                   @id @default(cuid())
  inboundEmailId   String
  method           EmailExtractionMethod
  status           EmailExtractionRunStatus @default(COMPLETED)
  extractorVersion String
  aiPromptVersion  String?
  requestId        String?
  notes            Json?
  inboundEmail     InboundEmail             @relation(fields: [inboundEmailId], references: [id], onDelete: Cascade)
  derivedOffers    EmailDerivedOffer[]
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@index([inboundEmailId, method, createdAt])
}

model EmailDerivedOffer {
  id                             String                       @id @default(cuid())
  inboundEmailId                 String
  extractionRunId                String?
  sourceDocumentId               String?
  status                         EmailDerivedOfferStatus      @default(STAGED)
  sourceKind                     String
  sourceBlockText                String
  rawProductText                 String?
  normalizedProductNameCandidate String?
  strengthCandidate              String?
  dosageFormCandidate            String?
  packSizeCandidate              String?
  manufacturerCandidate          String?
  supplierCandidate              String?
  priceCandidate                 Decimal?                     @db.Decimal(12, 2)
  currencyCandidate              String?
  minimumOrderQuantityCandidate  Int?
  availabilityCandidate          String?
  sourceTrustScore               Int?
  structureConfidence            Int?
  fieldConfidence                Int?
  entityResolutionConfidence     Int?
  promotionConfidence            Int?
  aiAssisted                     Boolean                      @default(false)
  reviewReason                   String?
  offerFingerprint               String?
  metadata                       Json?
  inboundEmail                   InboundEmail                 @relation(fields: [inboundEmailId], references: [id], onDelete: Cascade)
  extractionRun                  EmailExtractionRun?          @relation(fields: [extractionRunId], references: [id], onDelete: SetNull)
  sourceDocument                 InboundEmailDocument?        @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  evidences                      EmailDerivedOfferEvidence[]
  resolutionCandidates           EntityResolutionCandidate[]
  promotionDecisions             PromotionDecision[]
  workflowItem                   OfferWorkflowItem?
  buyDecision                    BuyDecision?
  tradeOpportunities             TradeOpportunity[]
  operatorFeedbacks              OperatorValidationFeedback[]
