model User {
  id                         String              @id @default(cuid())
  email                      String              @unique
  fullName                   String
  role                       UserRole            @default(ANALYST)
  isActive                   Boolean             @default(true)
  alerts                     Alert[]
  opportunities              Opportunity[]       @relation("OpportunityOwner")
  assignedOfferWorkflowItems OfferWorkflowItem[]
  ownedTradeOpportunities    TradeOpportunity[]  @relation("TradeOpportunityOwner")
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
}

model Product {
  id                        String              @id @default(cuid())
  sku                       String?             @unique
  name                      String
  /// Current imports persist the composite normalized product key here.
  /// This is not guaranteed to be the base-name-style normalized text.
  normalizedName            String
  /// Base-name-style normalized product text emitted by the normalizer when available.
  baseName                  String?
  manufacturer              String?
  strength                  String?
  dosageForm                String?
  packSize                  String?
  isActive                  Boolean             @default(true)
  aliases                   ProductAlias[]
  inventorySnapshots        InventorySnapshot[]
  opportunities             Opportunity[]
  salesRecords              SalesRecord[]
  supplierPriceItems        SupplierPriceItem[]
  buyDecisions              BuyDecision[]
  buyExecutions             BuyExecution[]
  tradeOpportunities        TradeOpportunity[]
  correctedOfferCorrections OfferCorrection[]
  regulatoryProductMatches  RegulatoryProductMatch[]
  regulatoryAlerts          RegulatoryAlert[]
  regulatoryReviewItems     RegulatoryReviewItem[]
  purchaseOrderLines        PurchaseOrderLine[]
  commercialIntelItems      CommercialIntelItem[]
  customerDemandSignals     CustomerDemandSignal[]
  demandSupplyMatches       DemandSupplyMatch[]
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt

  @@index([normalizedName])
}

model ProductAlias {
  id           String   @id @default(cuid())
  productId    String
  aliasName    String
  sourceSystem String?
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([aliasName])
  @@index([productId])
}

model ImportBatch {
  id                   String                @id @default(cuid())
  kind                 ImportKind
  status               ImportStatus          @default(COMPLETED)
  fileName             String
  fileMimeType         String?
  fileSizeBytes        Int?
  totalRows            Int                   @default(0)
  validRows            Int                   @default(0)
  invalidRows          Int                   @default(0)
  warnings             Json?
  errors               ImportError[]
  telegramInboundItems TelegramInboundItem[]
  inventorySnapshots   InventorySnapshot[]
  salesRecords         SalesRecord[]
  supplierPriceList    SupplierPriceList?
  uploadedAt           DateTime              @default(now())
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([kind, uploadedAt])
}

model ImportError {
  id            String      @id @default(cuid())
  importBatchId String
  rowNumber     Int?
  fieldName     String?
  message       String
  rawRow        Json?
  importBatch   ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([importBatchId, rowNumber])
}

model Supplier {
  id                        String                     @id @default(cuid())
  name                      String
  normalizedName            String
  country                   String?
  contactEmail              String?
  reliabilityScore          Float                      @default(0.5)
  isActive                  Boolean                    @default(true)
  inventorySnapshots        InventorySnapshot[]
  opportunities             Opportunity[]
  priceLists                SupplierPriceList[]
  salesRecords              SalesRecord[]
  supplierPriceItems        SupplierPriceItem[]
  qualification             SupplierQualification?
  buyDecisions              BuyDecision[]
  buyExecutions             BuyExecution[]
  tradeOpportunities        TradeOpportunity[]
  correctedOfferCorrections OfferCorrection[]
  sourceReliabilityProfiles SourceReliabilityProfile[]
  purchaseOrderLines        PurchaseOrderLine[]
  commercialIntelItems      CommercialIntelItem[]
  demandSupplyMatches       DemandSupplyMatch[]
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  @@unique([normalizedName])
}

model InboundEmail {
  id                        String                       @id @default(cuid())
  sourceSystem              String                       @default("MICROSOFT_GRAPH")
  externalMessageId         String?
  internetMessageId         String?
  conversationId            String?
  fromEmail                 String
  fromName                  String?
  subject                   String?
  rawHtml                   String?
  rawText                   String?
  bodyHash                  String?
  senderDomain              String?
  sourceTemplateFingerprint String?
  attachmentSummary         Json?
  processingStatus          InboundEmailProcessingStatus @default(RECEIVED)
  triageStatus              String?
  sourceTrustScore          Int?
  structureConfidence       Int?
  businessWorthinessScore   Int?
  parserConfidence          String?
  reviewReason              String?
  receivedAt                DateTime?
  processedAt               DateTime?
  documents                 InboundEmailDocument[]
  extractionRuns            EmailExtractionRun[]
  derivedOffers             EmailDerivedOffer[]
  offerWorkflowItems        OfferWorkflowItem[]
  buyDecisions              BuyDecision[]
  tradeOpportunities        TradeOpportunity[]
  offerCorrections          OfferCorrection[]
  promotionDecisions        PromotionDecision[]
  policyCheckResults        PolicyCheckResult[]
  promotedPriceLists        SupplierPriceList[]
  commercialIntelItems      CommercialIntelItem[]
  customerDemandSignals     CustomerDemandSignal[]
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt

  @@unique([sourceSystem, externalMessageId])
  @@index([fromEmail, createdAt])
  @@index([senderDomain, createdAt])
  @@index([sourceSystem, sourceTemplateFingerprint])
  @@index([processingStatus, createdAt])
}

model InboundEmailDocument {
  id             String                      @id @default(cuid())
  inboundEmailId String
  kind           InboundEmailDocumentKind
  documentIndex  Int
  label          String?
  textContent    String
  metadata       Json?
  inboundEmail   InboundEmail                @relation(fields: [inboundEmailId], references: [id], onDelete: Cascade)
  derivedOffers  EmailDerivedOffer[]
  evidences      EmailDerivedOfferEvidence[]
  commercialIntelItems CommercialIntelItem[]
  customerDemandSignals CustomerDemandSignal[]
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  @@unique([inboundEmailId, kind, documentIndex])
  @@index([inboundEmailId, kind, documentIndex])
}

model EmailExtractionRun {
  id               String                   @id @default(cuid())
  inboundEmailId   String
  method           EmailExtractionMethod
  status           EmailExtractionRunStatus @default(COMPLETED)
  extractorVersion String
  aiPromptVersion  String?
  requestId        String?
  notes            Json?
  inboundEmail     InboundEmail             @relation(fields: [inboundEmailId], references: [id], onDelete: Cascade)
  derivedOffers    EmailDerivedOffer[]
  evidences         EmailDerivedOfferEvidence[]
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@index([inboundEmailId, method, createdAt])
}

model EmailDerivedOffer {
  id                             String                       @id @default(cuid())
  inboundEmailId                 String
  extractionRunId                String?
  sourceDocumentId               String?
  status                         EmailDerivedOfferStatus      @default(STAGED)
  sourceKind                     String
  sourceBlockText                String
  rawProductText                 String?
  normalizedProductNameCandidate String?
  strengthCandidate              String?
  dosageFormCandidate            String?
  packSizeCandidate              String?
  manufacturerCandidate          String?
  supplierCandidate              String?
  priceCandidate                 Decimal?                     @db.Decimal(12, 2)
  currencyCandidate              String?
  minimumOrderQuantityCandidate  Int?
  availabilityCandidate          String?
  sourceTrustScore               Int?
  structureConfidence            Int?
  fieldConfidence                Int?
  entityResolutionConfidence     Int?
  promotionConfidence            Int?
  confidenceBreakdown            Json?
  confidenceExplanation          String?
  promotionBlockers              Json?
  policyCheckSummary             Json?
  aiAssisted                     Boolean                      @default(false)
  reviewReason                   String?
  offerFingerprint               String?
  metadata                       Json?
  inboundEmail                   InboundEmail                 @relation(fields: [inboundEmailId], references: [id], onDelete: Cascade)
  extractionRun                  EmailExtractionRun?          @relation(fields: [extractionRunId], references: [id], onDelete: SetNull)
  sourceDocument                 InboundEmailDocument?        @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  evidences                      EmailDerivedOfferEvidence[]
  resolutionCandidates           EntityResolutionCandidate[]
  promotionDecisions             PromotionDecision[]
  policyCheckResults             PolicyCheckResult[]
  workflowItem                   OfferWorkflowItem?
  buyDecision                    BuyDecision?
  tradeOpportunities             TradeOpportunity[]
  operatorFeedbacks              OperatorValidationFeedback[]
  offerCorrections               OfferCorrection[]
  createdAt                      DateTime                     @default(now())
  updatedAt                      DateTime                     @updatedAt

  @@unique([inboundEmailId, offerFingerprint])
  @@index([inboundEmailId, status, createdAt])
  @@index([sourceDocumentId])
}

model CommercialIntelItem {
  id                   String                      @id @default(cuid())
  inboundEmailId       String?
  sourceDocumentId     String?
  itemType             CommercialIntelItemType
  status               CommercialIntelStatus       @default(NEW)
  productText          String?
  productId            String?
  supplierName         String?
  supplierId           String?
  customerName         String?
  contactName          String?
  priceThreshold       Decimal?                    @db.Decimal(12, 2)
  currency             String?
  availabilitySignal   String?
  riskLevel            String?
  urgency              String?
  signalEffect         String?
  evidenceText         String
  confidence           CommercialIntelConfidence
  reviewReason         String?
  aiAssisted           Boolean                     @default(true)
  approvedByType       String?
  approvedByIdentifier String?
  approvedAt           DateTime?
  rejectedByType       String?
  rejectedByIdentifier String?
  rejectedAt           DateTime?
  validUntil           DateTime?
  itemFingerprint      String
  metadata             Json?
  inboundEmail         InboundEmail?               @relation(fields: [inboundEmailId], references: [id], onDelete: SetNull)
  sourceDocument       InboundEmailDocument?       @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  product              Product?                    @relation(fields: [productId], references: [id], onDelete: SetNull)
  supplier             Supplier?                   @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  @@unique([inboundEmailId, itemFingerprint])
  @@index([inboundEmailId, status, createdAt])
  @@index([productId, status, createdAt])
  @@index([supplierId, status, createdAt])
  @@index([itemType, status, createdAt])
}

model CustomerDemandSignal {
  id                   String                    @id @default(cuid())
  inboundEmailId       String?
  sourceDocumentId     String?
  status               CustomerDemandStatus      @default(NEW)
  requestType          CustomerDemandRequestType
  customerName         String?
  customerId           String?
  contactName          String?
  contactEmail         String?
  productText          String?
  productId            String?
  quantityRequested    Int?
  targetPrice          Decimal?                  @db.Decimal(12, 2)
  currency             String?
  neededByDate         DateTime?
  urgency              String?
  evidenceText         String
  confidence           CustomerDemandConfidence
  reviewReason         String?
  aiAssisted           Boolean                   @default(true)
  approvedByType       String?
  approvedByIdentifier String?
  approvedAt           DateTime?
  rejectedByType       String?
  rejectedByIdentifier String?
  rejectedAt           DateTime?
  validUntil           DateTime?
  itemFingerprint      String
  metadata             Json?
  inboundEmail         InboundEmail?             @relation(fields: [inboundEmailId], references: [id], onDelete: SetNull)
  sourceDocument       InboundEmailDocument?     @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  customer             Customer?                 @relation(fields: [customerId], references: [id], onDelete: SetNull)
  product              Product?                  @relation(fields: [productId], references: [id], onDelete: SetNull)
  demandSupplyMatches  DemandSupplyMatch[]
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  @@unique([inboundEmailId, itemFingerprint])
  @@index([inboundEmailId, status, createdAt])
  @@index([productId, status, createdAt])
  @@index([customerId, status, createdAt])
  @@index([requestType, status, createdAt])
}

model DemandSupplyMatch {
  id                     String                      @id @default(cuid())
  customerDemandSignalId String
  supplierPriceItemId    String
  productId              String
  customerId             String?
  supplierId             String?
  status                 DemandSupplyMatchStatus     @default(NEW)
  reason                 DemandSupplyMatchReason
  confidence             DemandSupplyMatchConfidence
  matchScore             Int?
  rawCustomerProductText String?
  rawSupplierProductText String?
  quantityRequested      Int?
  requestedTargetPrice   Decimal?                    @db.Decimal(12, 2)
  requestedCurrency      String?
  supplierUnitPrice      Decimal?                    @db.Decimal(12, 2)
  supplierCurrency       String?
  estimatedMarginAmount  Decimal?                    @db.Decimal(12, 2)
  estimatedMarginPct     Decimal?                    @db.Decimal(8, 4)
  marginExplanation      String?
  urgency                String?
  riskFlags              Json?
  rationale              String
  evidence               Json?
  commercialIntelContext Json?
  customerDemandContext  Json?
  supplierOfferContext   Json?
  matchFingerprint       String
  reviewedByType         String?
  reviewedByIdentifier   String?
  reviewedAt             DateTime?
  rejectedByType         String?
  rejectedByIdentifier   String?
  rejectedAt             DateTime?
  promotedByType         String?
  promotedByIdentifier   String?
  promotedAt             DateTime?
  expiresAt              DateTime?
  metadata               Json?
  customerDemandSignal   CustomerDemandSignal        @relation(fields: [customerDemandSignalId], references: [id], onDelete: Cascade)
  supplierPriceItem      SupplierPriceItem           @relation(fields: [supplierPriceItemId], references: [id], onDelete: Cascade)
  product                Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer               Customer?                   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  supplier               Supplier?                   @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt

  @@unique([customerDemandSignalId, supplierPriceItemId], map: "DemandSupplyMatch_demand_price_key")
  @@index([status, createdAt])
  @@index([productId, status, createdAt])
  @@index([customerDemandSignalId, status])
  @@index([supplierPriceItemId, status])
  @@index([customerId, status, createdAt])
  @@index([supplierId, status, createdAt])
  @@index([matchFingerprint])
}

model OfferWorkflowItem {
  id                              String                       @id @default(cuid())
  emailDerivedOfferId             String                       @unique
  inboundEmailId                  String?
  status                          OfferWorkflowStatus          @default(NEW)
  priority                        OfferWorkflowPriority        @default(MEDIUM)
  priorityReason                  String?
  assigneeUserId                  String?
  assigneeLabel                   String?
  latestNote                      String?
  sourceKind                      String?
  sourceReviewReason              String?
  aiAssisted                      Boolean                      @default(false)
  hasUnresolvedSupplier           Boolean                      @default(false)
  hasConflictingSupplierCues      Boolean                      @default(false)
  hasManufacturerAmbiguity        Boolean                      @default(false)
  supplierQualificationStatus     SupplierQualificationStatus  @default(UNKNOWN)
  hasUnknownSupplierQualification Boolean                      @default(true)
  hasRestrictedSupplier           Boolean                      @default(false)
  hasBlockedSupplier              Boolean                      @default(false)
  qualificationRiskNote           String?
  createdByType                   String                       @default("SYSTEM")
  createdByIdentifier             String?
  completedAt                     DateTime?
  emailDerivedOffer               EmailDerivedOffer            @relation(fields: [emailDerivedOfferId], references: [id], onDelete: Cascade)
  inboundEmail                    InboundEmail?                @relation(fields: [inboundEmailId], references: [id], onDelete: SetNull)
  assigneeUser                    User?                        @relation(fields: [assigneeUserId], references: [id], onDelete: SetNull)
  events                          OfferWorkflowEvent[]
  buyDecision                     BuyDecision?
  tradeOpportunities              TradeOpportunity[]
  operatorFeedbacks               OperatorValidationFeedback[]
