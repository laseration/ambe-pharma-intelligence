generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ANALYST
  SALES
  OPS
}

enum OpportunityType {
  BUY
  PUSH
  DEAD_STOCK
  PRICE_ALERT
}

enum OpportunityStatus {
  OPEN
  REVIEWED
  ACTIONED
  DISMISSED
}

enum AlertType {
  INVENTORY
  PRICE
  SALES
  OPPORTUNITY
  SYSTEM
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum TelegramPostStatus {
  PENDING
  SENT
  FAILED
}

enum SettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  fullName       String
  role           UserRole      @default(ANALYST)
  isActive       Boolean       @default(true)
  alerts         Alert[]
  opportunities  Opportunity[] @relation("OpportunityOwner")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Product {
  id                 String              @id @default(cuid())
  sku                String?             @unique
  name               String
  normalizedName     String
  manufacturer       String?
  strength           String?
  dosageForm         String?
  packSize           String?
  isActive           Boolean             @default(true)
  aliases            ProductAlias[]
  inventorySnapshots InventorySnapshot[]
  opportunities      Opportunity[]
  salesRecords       SalesRecord[]
  supplierPriceItems SupplierPriceItem[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([normalizedName])
}

model ProductAlias {
  id           String   @id @default(cuid())
  productId    String
  aliasName    String
  sourceSystem String?
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([aliasName])
  @@index([productId])
}

model Supplier {
  id                 String              @id @default(cuid())
  name               String
  normalizedName     String
  country            String?
  contactEmail       String?
  isActive           Boolean             @default(true)
  inventorySnapshots InventorySnapshot[]
  opportunities      Opportunity[]
  priceLists         SupplierPriceList[]
  salesRecords       SalesRecord[]
  supplierPriceItems SupplierPriceItem[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([normalizedName])
}

model SupplierPriceList {
  id              String              @id @default(cuid())
  supplierId      String
  fileName        String
  sourceDate      DateTime?
  uploadedAt      DateTime            @default(now())
  currencyCode    String              @default("USD")
  notes           String?
  supplier        Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierPrices  SupplierPriceItem[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([supplierId, uploadedAt])
}

model SupplierPriceItem {
  id                    String             @id @default(cuid())
  supplierPriceListId   String
  supplierId            String
  productId             String?
  rawProductName        String
  normalizedProductName String?
  packDescription       String?
  unitPrice             Decimal            @db.Decimal(12, 2)
  currencyCode          String             @default("USD")
  minimumOrderQuantity  Int?
  isAvailable           Boolean            @default(true)
  product               Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)
  supplier              Supplier           @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierPriceList     SupplierPriceList  @relation(fields: [supplierPriceListId], references: [id], onDelete: Cascade)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([supplierId, rawProductName])
  @@index([productId])
  @@index([supplierPriceListId])
}

model InventorySnapshot {
  id                String    @id @default(cuid())
  productId         String
  supplierId        String?
  warehouseCode     String
  snapshotDate      DateTime
  quantityOnHand    Int
  quantityReserved  Int       @default(0)
  quantityAvailable Int
  unitCost          Decimal?  @db.Decimal(12, 2)
  totalValue        Decimal?  @db.Decimal(14, 2)
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier          Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([productId, snapshotDate])
  @@index([warehouseCode, snapshotDate])
}

model Customer {
  id                  String        @id @default(cuid())
  name                String
  normalizedName      String
  legalEntityName     String?
  country             String?
  city                String?
  primaryContactEmail String?
  isActive            Boolean       @default(true)
  opportunities       Opportunity[]
  salesRecords        SalesRecord[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([normalizedName])
}

model SalesRecord {
  id            String    @id @default(cuid())
  saleDate      DateTime
  customerId    String
  productId     String
  supplierId    String?
  quantity      Int
  unitPrice     Decimal   @db.Decimal(12, 2)
  totalRevenue  Decimal   @db.Decimal(14, 2)
  currencyCode  String    @default("USD")
  customer      Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier      Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([saleDate])
  @@index([customerId, saleDate])
  @@index([productId, saleDate])
}

model Opportunity {
  id              String            @id @default(cuid())
  type            OpportunityType
  status          OpportunityStatus @default(OPEN)
  title           String
  description     String?
  score           Int
  customerId      String?
  productId       String?
  supplierId      String?
  ownerUserId     String?
  dueDate         DateTime?
  customer        Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  owner           User?             @relation("OpportunityOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  product         Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  supplier        Supplier?         @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  alerts          Alert[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([type, status])
  @@index([customerId])
  @@index([productId])
}

model Alert {
  id             String       @id @default(cuid())
  type           AlertType
  status         AlertStatus  @default(OPEN)
  title          String
  message        String
  userId         String?
  opportunityId  String?
  triggeredAt    DateTime     @default(now())
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  opportunity    Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([status, triggeredAt])
  @@index([userId])
}

model TelegramPost {
  id               String             @id @default(cuid())
  channelKey       String
  status           TelegramPostStatus @default(PENDING)
  messageText      String
  telegramMessageId String?
  sentAt           DateTime?
  errorMessage     String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([channelKey, status])
}

model AppSetting {
  id          String      @id @default(cuid())
  key         String      @unique
  value       String
  type        SettingType @default(STRING)
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}
