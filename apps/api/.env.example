PORT=4000
NODE_ENV=development
LOG_LEVEL=info
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"
INTERNAL_API_KEY=
INTERNAL_ADMIN_API_KEY=
ENABLE_DEBUG_ROUTES=true

# ========================
# TELEGRAM
# ========================
TELEGRAM_BOT_TOKEN=
TELEGRAM_INTERNAL_CHAT_ID=
TELEGRAM_DRY_RUN=true
TELEGRAM_POLLING_ENABLED=false
TELEGRAM_POLLING_INTERVAL_MS=5000
# Comma-separated Telegram user IDs allowed to submit files.
TELEGRAM_ALLOWED_USER_IDS=
# Comma-separated Telegram chat IDs allowed to submit files.
TELEGRAM_ALLOWED_CHAT_IDS=

# ========================
# EMAIL (OUTBOUND/INBOUND VIA MICROSOFT GRAPH)
# Microsoft Graph mail app - Ambe Bot Mailer.
MICROSOFT_MAIL_TENANT_ID=
MICROSOFT_MAIL_CLIENT_ID=
MICROSOFT_MAIL_CLIENT_SECRET=
# Backwards-compatible legacy mailer vars. Prefer MICROSOFT_MAIL_* for new setup.
MICROSOFT_GRAPH_TENANT_ID=
MICROSOFT_GRAPH_CLIENT_ID=
MICROSOFT_GRAPH_CLIENT_SECRET=
# Refresh token for delegated sending/inbox polling, useful for personal Outlook.com mailboxes.
MICROSOFT_GRAPH_REFRESH_TOKEN=
# Mailbox address used in Graph sendMail and inbox polling, for example alerts@yourcompany.com.
MICROSOFT_GRAPH_SENDER_MAILBOX=
# Comma-separated internal recipient list.
INTERNAL_ALERT_EMAIL_RECIPIENTS=

# ACCOUNT OPENING MICROSOFT DRIVE STORAGE
# Provider defaults to SHAREPOINT for backwards compatibility. Use ONEDRIVE for a company user's OneDrive.
ACCOUNT_OPENING_STORAGE_PROVIDER=SHAREPOINT
MICROSOFT_DRIVE_ROOT_FOLDER="AI BOT FOLDER"
# Microsoft Graph storage app - Ambe Bot SharePoint Upload.
# Requires application permissions Sites.ReadWrite.All and Files.ReadWrite.All with admin consent.
MICROSOFT_STORAGE_TENANT_ID=
MICROSOFT_STORAGE_CLIENT_ID=
MICROSOFT_STORAGE_CLIENT_SECRET=
SHAREPOINT_ACCOUNT_OPENING_ENABLED=false
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=
SHAREPOINT_ACCOUNT_OPENING_FOLDER="AI BOT FOLDER/Account Opening"
ONEDRIVE_ACCOUNT_OPENING_ENABLED=false
# Microsoft Graph user ID or user principal name, for example sandeep@yourcompany.com.
ONEDRIVE_USER_ID=
# Optional. If blank and ONEDRIVE_USER_ID is set, the diagnostic/uploader resolves it with GET /users/{ONEDRIVE_USER_ID}/drive.
ONEDRIVE_DRIVE_ID=
# Workflow folders default to MICROSOFT_DRIVE_ROOT_FOLDER plus the workflow name.
ONEDRIVE_ACCOUNT_OPENING_FOLDER="AI BOT FOLDER/Account Opening"
ONEDRIVE_PRICE_LIST_FOLDER="AI BOT FOLDER/Price Lists"
ONEDRIVE_PURCHASE_ORDER_FOLDER="AI BOT FOLDER/Purchase Orders"
ONEDRIVE_REGULATORY_FOLDER="AI BOT FOLDER/Regulatory"
ONEDRIVE_REPORTS_FOLDER="AI BOT FOLDER/Reports"
# Safe Microsoft Drive access diagnostic:
# pnpm --filter @ambe/api microsoft-drive:check
# Read-only by default. To explicitly upload and then delete a harmless test file:
# pnpm --filter @ambe/api microsoft-drive:check -- --write-test
# The write test uses AI BOT FOLDER/Health Checks/microsoft-drive-health-check.txt with safe text only.
# Backwards-compatible legacy generic Graph vars for storage fallback only.
# Do not use the mailer app client ID for SharePoint upload checks.
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ========================
# EMAIL INBOUND
# ========================
# Poll the Microsoft Graph inbox directly instead of relying on a forwarded webhook.
EMAIL_INBOUND_POLLING_ENABLED=false
EMAIL_INBOUND_POLLING_INTERVAL_MS=30000
# Comma-separated exact addresses or trusted domains.
# Examples:
# EMAIL_INBOUND_ALLOWED_SENDERS=owner@ambe.test,supplier@example.com,supplier.co
EMAIL_INBOUND_ALLOWED_SENDERS=
# Optional exact-address or domain -> supplier name mapping for direct supplier emails.
# Forwarded owner emails may instead send supplierName in the inbound message payload.
EMAIL_INBOUND_SUPPLIER_MAPPINGS=
# Internal company identity that should never be treated as an external supplier cue.
EMAIL_INBOUND_INTERNAL_DOMAINS=ambemedical.com
EMAIL_INBOUND_INTERNAL_COMPANY_NAMES=Ambe Medical,Ambe Medical Group,Ambemedical,Ambe Pharma

# ========================
# OPENAI
# ========================
OPENAI_API_KEY=
OPENAI_PARSER_ENABLED=false
# Keep configurable; example model:
OPENAI_PARSER_MODEL=gpt-5.4
OPENAI_PARSER_TIMEOUT_MS=8000
OPENAI_PARSER_MIN_CHARS=24
OPENAI_PARSER_MAX_CHARS=4000
OPENAI_EMAIL_REVIEW_ENABLED=false
OPENAI_EMAIL_REVIEW_DAILY_LIMIT=10
OPENAI_EMAIL_REVIEW_PER_SUPPLIER_DAILY_LIMIT=2
OPENAI_EMAIL_REVIEW_MIN_BUSINESS_SCORE=65

# ========================
# BUSINESS MODE
# ========================
OPPORTUNITY_BUSINESS_MODE=TRADING
