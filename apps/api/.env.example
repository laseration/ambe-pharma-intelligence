PORT=4000
NODE_ENV=development
LOG_LEVEL=info
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"
INTERNAL_API_KEY=
INTERNAL_ADMIN_API_KEY=
ENABLE_DEBUG_ROUTES=true

# ========================
# TELEGRAM
# ========================
TELEGRAM_BOT_TOKEN=
TELEGRAM_INTERNAL_CHAT_ID=
TELEGRAM_DRY_RUN=true
TELEGRAM_POLLING_ENABLED=false
TELEGRAM_POLLING_INTERVAL_MS=5000
# Comma-separated Telegram user IDs allowed to submit files.
TELEGRAM_ALLOWED_USER_IDS=
# Comma-separated Telegram chat IDs allowed to submit files.
TELEGRAM_ALLOWED_CHAT_IDS=

# ========================
# EMAIL (OUTBOUND VIA MICROSOFT GRAPH)
# App registration client ID.
MICROSOFT_GRAPH_CLIENT_ID=
# App registration client secret for app-only business-tenant sending/inbox polling.
MICROSOFT_GRAPH_CLIENT_SECRET=
# Microsoft Entra tenant ID.
MICROSOFT_GRAPH_TENANT_ID=
# Refresh token for delegated sending/inbox polling, useful for personal Outlook.com mailboxes.
MICROSOFT_GRAPH_REFRESH_TOKEN=
# Mailbox address used in Graph sendMail and inbox polling, for example alerts@yourcompany.com.
MICROSOFT_GRAPH_SENDER_MAILBOX=
# Comma-separated internal recipient list.
INTERNAL_ALERT_EMAIL_RECIPIENTS=

SHAREPOINT_ACCOUNT_OPENING_ENABLED=false
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=
SHAREPOINT_ACCOUNT_OPENING_FOLDER=
# Optional aliases used by SharePoint archive upload when MICROSOFT_GRAPH_* is not set.
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=


# ========================
# EMAIL INBOUND
# ========================
# Poll the Microsoft Graph inbox directly instead of relying on a forwarded webhook.
EMAIL_INBOUND_POLLING_ENABLED=false
EMAIL_INBOUND_POLLING_INTERVAL_MS=30000
# Comma-separated exact addresses or trusted domains.
# Examples:
# EMAIL_INBOUND_ALLOWED_SENDERS=owner@ambe.test,supplier@example.com,supplier.co
EMAIL_INBOUND_ALLOWED_SENDERS=
# Optional exact-address or domain -> supplier name mapping for direct supplier emails.
# Forwarded owner emails may instead send supplierName in the inbound message payload.
EMAIL_INBOUND_SUPPLIER_MAPPINGS=
# Internal company identity that should never be treated as an external supplier cue.
EMAIL_INBOUND_INTERNAL_DOMAINS=ambemedical.com
EMAIL_INBOUND_INTERNAL_COMPANY_NAMES=Ambe Medical,Ambe Medical Group,Ambemedical,Ambe Pharma

# ========================
# OPENAI
# ========================
OPENAI_API_KEY=
# Controls OpenAI fallback inside the supplier-offer parser, commercial-intel extraction,
# and customer-request extraction.
# Deterministic supplier-offer parsing still runs first.
OPENAI_PARSER_ENABLED=false
# Keep configurable; example model:
OPENAI_PARSER_MODEL=gpt-5.4
OPENAI_PARSER_TIMEOUT_MS=8000
OPENAI_PARSER_MIN_CHARS=24
OPENAI_PARSER_MAX_CHARS=4000
# Legacy/review-triage budget controls. These do not enable or disable parser fallback.
OPENAI_EMAIL_REVIEW_ENABLED=false
OPENAI_EMAIL_REVIEW_DAILY_LIMIT=10
OPENAI_EMAIL_REVIEW_PER_SUPPLIER_DAILY_LIMIT=2
OPENAI_EMAIL_REVIEW_MIN_BUSINESS_SCORE=65

# ========================
# BUSINESS MODE
# ========================
OPPORTUNITY_BUSINESS_MODE=TRADING
