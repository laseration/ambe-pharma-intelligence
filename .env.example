NODE_ENV=development
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"
INTERNAL_API_KEY=
INTERNAL_ADMIN_API_KEY=
ACCOUNT_OPENING_EXPORT_DOWNLOAD_TOKEN=

# Microsoft Graph mail app - Ambe Bot Mailer
MICROSOFT_MAIL_TENANT_ID=
MICROSOFT_MAIL_CLIENT_ID=
MICROSOFT_MAIL_CLIENT_SECRET=

# Microsoft Graph storage app - Ambe Bot SharePoint Upload
MICROSOFT_STORAGE_TENANT_ID=
MICROSOFT_STORAGE_CLIENT_ID=
MICROSOFT_STORAGE_CLIENT_SECRET=

# Backwards-compatible legacy generic Graph vars
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

SHAREPOINT_ACCOUNT_OPENING_ENABLED=false
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=
SHAREPOINT_ACCOUNT_OPENING_FOLDER=

GRAPH_USE_MESSAGE_DELTA=true
GRAPH_USE_IMMUTABLE_IDS=true
INBOUND_CLASSIFIER_ENABLED=true
INBOUND_CLASSIFIER_SHADOW_MODE=true
SUPPLIER_CONTACT_AUTO_ACCEPT_ENABLED=false
ACCOUNT_OPENING_ORIGINAL_UPLOAD_ENABLED=false
ACCOUNT_OPENING_AUTOFILL_ENABLED=false
ACCOUNT_OPENING_AUTO_FILE_SHAREPOINT_ENABLED=false
ACCOUNT_OPENING_FORBIDDEN_FIELDS_ENFORCED=true
ACCOUNT_OPENING_MIN_CLASSIFIER_SCORE=75
